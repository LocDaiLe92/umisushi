@page "/bestil-take-away"
@using UmiSushi.Web.Services
@using UmiSushi.Web.Components.Shared

<PageTitle>Bestil Take-Away – UmiSushi Ry</PageTitle>

<HeadContent>
    <meta name="description" content="Bestil sushi take-away fra UmiSushi i Ry. Vælg dine favoritretter online og afhent dem i restauranten." />
    <meta property="og:title" content="Bestil Take-Away – UmiSushi Ry" />
    <meta property="og:url" content="@(SiteConfig.SiteUrl)/bestil-take-away" />
    <link rel="canonical" href="@(SiteConfig.SiteUrl)/bestil-take-away" />
</HeadContent>

<!-- Header -->
<div style="background:var(--color-dark);padding:5rem 0 3rem;border-bottom:1px solid var(--color-border);">
    <div class="umi-container">
        <span class="section-label">Afhent din sushi</span>
        <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Bestil Take-Away</h1>
        <p class="section-subtitle" style="margin-left:0;">Vælg dine favoritretter online – vi sørger for at de er klar, når du ankommer.</p>
    </div>
</div>

<section class="umi-section">
    <div class="umi-container">
        <div class="takeaway-hero">
            <h2 style="font-family:var(--font-serif);font-size:2rem;color:var(--color-text);margin-bottom:1rem;">
                Klar til afhentning
            </h2>
            <p style="color:var(--color-muted);font-size:1rem;line-height:1.7;margin-bottom:2rem;">
                Vores online bestillingssystem gør det nemt at sammensætte din ordre.<br />
                Vi tilbereder din sushi frisk, så du kan afhente den i restauranten.
            </p>
            <a href="@SiteConfig.TakeawayUrl" target="_blank" rel="noopener noreferrer" class="btn-primary" style="font-size:1rem;padding:1rem 2.5rem;">
                Klik her og bestil nu
            </a>
        </div>

        <!-- How it works -->
        <div style="margin-top:5rem;text-align:center;">
            <SectionHeading Label="Sådan gør du" Title="3 simple trin" />
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:2.5rem;">
                <div style="text-align:center;padding:2rem;">
                    <div style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:0.75rem;">01</div>
                    <div style="font-family:var(--font-serif);font-size:1.1rem;color:var(--color-text);margin-bottom:0.5rem;">Vælg dine retter</div>
                    <p style="font-size:0.9rem;color:var(--color-muted);">Gennemse vores menukort og sammensæt din ordre online.</p>
                </div>
                <div style="text-align:center;padding:2rem;">
                    <div style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:0.75rem;">02</div>
                    <div style="font-family:var(--font-serif);font-size:1.1rem;color:var(--color-text);margin-bottom:0.5rem;">Angiv afhentning</div>
                    <p style="font-size:0.9rem;color:var(--color-muted);">Vælg tidspunkt for afhentning i restauranten i Ry.</p>
                </div>
                <div style="text-align:center;padding:2rem;">
                    <div style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-muted);margin-bottom:0.75rem;">03</div>
                    <div style="font-family:var(--font-serif);font-size:1.1rem;color:var(--color-text);margin-bottom:0.5rem;">Afhent din sushi</div>
                    <p style="font-size:0.9rem;color:var(--color-muted);">Vi tilbereder frisk – du afhenter og nyder.</p>
                </div>
            </div>
        </div>

        <!-- Contact -->
        <div style="margin-top:4rem;text-align:center;padding:2rem;background:var(--color-surface);border:1px solid var(--color-border);">
            <p style="color:var(--color-muted);margin-bottom:0.75rem;">Spørgsmål? Ring til os på</p>
            <a href="tel:@SiteConfig.Phone" style="font-family:var(--font-serif);font-size:1.75rem;color:var(--color-gold);text-decoration:none;">
                @SiteConfig.PhoneDisplay
            </a>
        </div>
    </div>
</section>
